{
  "github.copilot.enable": {
    "*": false
  },
  "[zig]": {
    "editor.tabSize": 4,
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false,
    "editor.defaultFormatter": "ziglang.vscode-zig",
    "editor.stickyScroll.defaultModel": "foldingProviderModel",
    "files.eol": "\n"
  }
}
